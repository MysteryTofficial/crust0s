[Trigger]
Operation = Upgrade
Type = Package
Target = linux*
Target = systemd
Target = nvidia*
Target = mesa*
Target = cosmic-*
Target = pipewire*
Target = calamares

[Action]
Description = Creating pre-upgrade BTRFS snapshot …
When = PreTransaction
Exec = /usr/bin/snapper --config root create --description "pre-%PKGNAME%" --cleanup-algorithm number
