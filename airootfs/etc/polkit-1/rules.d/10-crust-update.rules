// Crust OS — allow members of wheel to update the system
polkit.addRule(function(action, subject) {
  if (action.id == "org.archlinux.pacman.install" ||
      action.id == "org.archlinux.pacman.update" ||
      action.id == "org.archlinux.pacman.remove" ||
      action.id == "org.freedesktop.policykit.exec" &&
      action.lookup("program") == "/usr/bin/pacman") {
    if (subject.isInGroup("wheel")) {
      return polkit.Result.YES;
    }
  }
});

// Allow firmware updates without admin
polkit.addRule(function(action, subject) {
  if (action.id == "org.freedesktop.fwupd" ||
      action.id == "org.freedesktop.fwupd.*") {
    return polkit.Result.YES;
  }
});
