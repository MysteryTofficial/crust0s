#!/usr/bin/env bash
#
# crust-snap-boot — generate systemd-boot entries for BTRFS snapshots
#
set -euo pipefail

SNAPSHOTS_ROOT="/.snapshots"
LOADER_DIR="/boot/loader/entries"

KERNEL_LTS="/vmlinuz-linux-lts"
INITRAMFS_LTS="/initramfs-linux-lts.img"
KERNEL_ZEN="/vmlinuz-linux-zen"
INITRAMFS_ZEN="/initramfs-linux-zen.img"
CMDLINE_SUFFIX="rw quiet splash loglevel=3 rd.systemd.show_status=false rd.udev.log_priority=3 vt.global_cursor_default=0 i915.enable_psr=1 amdgpu.dcfeaturemask=0x2"

# -- guards
[ -d "$SNAPSHOTS_ROOT" ] || { echo "[!] $SNAPSHOTS_ROOT not found — skipping" >&2; exit 0; }
[ -d "$LOADER_DIR" ]     || { echo "[!] $LOADER_DIR not found — skipping" >&2;     exit 0; }

# -- determine root PARTUUID
root_cmdline="root=UUID=root"
root_dev="$(findmnt -n -o SOURCE / 2>/dev/null || true)"
if [ -n "$root_dev" ]; then
  part_uuid="$(blkid -s PARTUUID -o value "$root_dev" 2>/dev/null || true)"
  [ -n "$part_uuid" ] && root_cmdline="root=PARTUUID=${part_uuid}"
fi

# -- only reference microcode images that actually exist
initrd_ucode=""
for img in /intel-ucode.img /amd-ucode.img; do
  [ -f "$img" ] && initrd_ucode="${initrd_ucode}initrd ${img}\n"
done

# -- purge stale snapshot entries
find "$LOADER_DIR" -name 'crust-snap-*' -delete 2>/dev/null || true

# -- iterate snapper snapshots
while IFS= read -r snap_dir; do
  [ -z "$snap_dir" ] && continue
  snap_number="${snap_dir##*/}"
  description="snapshot ${snap_number}"

  info_file="$(dirname "$snap_dir")/info.xml"
  [ -f "$info_file" ] && description=$(grep -oP '<description>\K[^<]+' "$info_file" 2>/dev/null || echo "$description")

  # resolve the actual subvolume path from the snapshot
  subvol="${snap_dir}"

  for variant in lts zen; do
    case "$variant" in
      lts) kver="$KERNEL_LTS"; iram="$INITRAMFS_LTS";;
      zen) kver="$KERNEL_ZEN"; iram="$INITRAMFS_ZEN";;
    esac

    # skip if kernel files are missing
    [ -f "$kver" ] || continue

    entry_file="$LOADER_DIR/crust-snap-${snap_number}-${variant}.conf"

    {
      echo "title   Crust OS (snapshot #${snap_number}) — ${description}"
      echo "sort-key snap-${variant}-${snap_number}"
      echo "linux   ${kver}"
      echo -e "$initrd_ucode"
      echo "initrd  ${iram}"
      echo "options ${root_cmdline} rootflags=subvol=${subvol#/} ${CMDLINE_SUFFIX}"
    } > "$entry_file"

    echo "[+] crust-snap-boot: ${variant} entry #${snap_number} — ${description}"
  done
done < <(find "$SNAPSHOTS_ROOT" -maxdepth 2 -name 'snapshot' -type d 2>/dev/null | sort -t/ -k4 -n)
