#!/usr/bin/env bash
#
# crust-update-check — check GitHub-hosted repo for Crust OS updates
#
set -euo pipefail

CONF=/etc/crust-update.conf
CACHE=/var/lib/crust-update/known.json
LOG=/var/log/crust-update.log

REPO_URL="https://raw.githubusercontent.com/crust-os/crust-os-repo/main"

[ -f "$CONF" ] && . "$CONF"

exec > >(tee -a "$LOG") 2>&1

# -- ensure dependencies are available
command -v curl &>/dev/null || { echo "[!] curl not found" >&2; exit 1; }
command -v jq   &>/dev/null || { echo "[!] jq not found" >&2;     exit 1; }

# ------------------------------------------------------------------
fetch_manifest() {
  curl -sfL "${REPO_URL}/update.json" 2>/dev/null || {
    echo "[!] Failed to fetch manifest from ${REPO_URL}/update.json" >&2
    return 1
  }
}

# ------------------------------------------------------------------
# returns 0 if a > b (semver-ish)
# ------------------------------------------------------------------
version_gt() {
  [ -z "$1" ] && return 1
  [ -z "$2" ] && return 0
  [ "$1" = "$2" ] && return 1
  [ "$(printf '%s\n' "$1" "$2" | sort -V | tail -1)" = "$1" ]
}

# ------------------------------------------------------------------
check_updates() {
  local manifest
  manifest=$(fetch_manifest) || return 1

  local count=0

  while IFS= read -r line; do
    local name version type description severity
    name=$(echo "$line" | jq -r '.name // empty')
    version=$(echo "$line" | jq -r '.version // empty')
    type=$(echo "$line" | jq -r '.type // "package"')
    description=$(echo "$line" | jq -r '.description // empty')
    severity=$(echo "$line" | jq -r '.severity // "info"')

    [ -z "$name" ] && continue

    case "$type" in
      package)
        local installed=""
        installed=$(pacman -Q "$name" 2>/dev/null | awk '{print $2}' || true)
        if [ -n "$installed" ] && version_gt "$version" "$installed"; then
          count=$((count + 1))
          echo "UPDATE|${name}|${installed}|${version}|${type}|${description}|${severity}"
        fi
        ;;
      iso)
        local current
        current=$(cat /etc/crust-version 2>/dev/null || echo "0")
        echo "UPDATE|crust-os-iso|${current}|${version}|iso|${description}|${severity}"
        count=$((count + 1))
        ;;
      system)
        echo "UPDATE|${name}|-|${version}|system|${description}|${severity}"
        count=$((count + 1))
        ;;
    esac
  done < <(echo "$manifest" | jq -c '.packages[]? // []' 2>/dev/null || true)

  echo "$manifest" > "$CACHE"
  echo "$count"
}

# ------------------------------------------------------------------
notify() {
  local count=$1
  command -v notify-send &>/dev/null || return 0
  if [ "$count" -gt 0 ]; then
    notify-send -u normal \
      "Crust OS: $count update$([ "$count" -ne 1 ] && echo s) available" \
      "Open Crust Update in Settings to install."
  fi
}

# ------------------------------------------------------------------
main() {
  local updates_count=0

  case "${1:-}" in
    --json)
      updates=$(check_updates)
      {
        echo "$updates" | grep '^UPDATE|' | while IFS='|' read -r _ name old new type desc sev; do
          jq -n \
            --arg name "$name" \
            --arg old "$old" \
            --arg new "$new" \
            --arg type "$type" \
            --arg desc "$desc" \
            --arg sev "$sev" \
            '{name: $name, old: $old, new: $new, type: $type, description: $desc, severity: $sev}'
        done
      } | jq -s '{updates: .}' 2>/dev/null || echo '{"updates": []}'
      ;;
    --notify)
      updates=$(check_updates)
      updates_count=$(echo "$updates" | grep -c '^UPDATE|' || true)
      notify "$updates_count"
      [ "$updates_count" -gt 0 ] && exit 0
      ;;
    *)
      check_updates
      ;;
  esac
}

main "$@"
